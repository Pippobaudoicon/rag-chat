# =============================================================================
# rag-chat — Environment Variables Template
# Copy this to .env.local and fill in the values.
# Most secrets are injected automatically via Vercel Marketplace integrations.
# Run: vercel env pull .env.local --yes
# =============================================================================

# Clerk Auth (provisioned via: vercel integration add clerk)
# Vercel previews need a real publishable key. Local .clerk keyless files are ignored.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Optional server-side fallback for environments where only CLERK_PUBLISHABLE_KEY is set.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Neon Postgres (provisioned via: vercel integration add neon)
DATABASE_URL=

# Upstash Redis (provisioned via: vercel integration add upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Voyage AI — same API key as the hymns/ Python app
VOYAGE_API_KEY=

# Pinecone — same API key as hymns/ (read-only operations here)
PINECONE_API_KEY=

# Optional override. Defaults to deepseek/deepseek-v4-flash in src/app/api/chat/route.ts.
CHAT_MODEL=deepseek/deepseek-v4-flash

# Vercel AI Gateway (DO NOT set manually — auto-provisioned via vercel env pull)
# VERCEL_OIDC_TOKEN=
